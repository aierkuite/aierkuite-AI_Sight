# Backend configuration template.
# Copy to backend/.env and fill in real values. .env is gitignored — never commit real secrets.

# --- Required (no defaults; a missing or empty value aborts startup) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_MODEL=your-vision-capable-model

# --- Optional (defaults shown) ---
MAX_HISTORY_ROUNDS=6
MAX_IMAGE_BYTES=2000000
REQUEST_TIMEOUT_SECONDS=60
CORS_ALLOW_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
