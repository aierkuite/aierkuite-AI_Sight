# 后端配置模板
# 复制为 backend/.env 后填写真实值，.env 已被 gitignore，禁止提交真实密钥

# --- 必填项（缺失或为空会导致启动失败） ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_MODEL=your-vision-capable-model
# 日文参考音频，填写 GPT-SoVITS 服务进程可访问的路径
GPT_SOVITS_REF_AUDIO_PATH=
# 日文转写文本，必须与参考音频内容一致
GPT_SOVITS_PROMPT_TEXT=

# --- 可选项（展示默认值） ---
MAX_HISTORY_ROUNDS=6
MAX_IMAGE_BYTES=2000000
REQUEST_TIMEOUT_SECONDS=60
CORS_ALLOW_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
GPT_SOVITS_BASE_URL=http://127.0.0.1:9880
GPT_SOVITS_PROMPT_LANG=ja
GPT_SOVITS_TEXT_LANG=ja
GPT_SOVITS_TEXT_SPLIT_METHOD=cut0
GPT_SOVITS_TIMEOUT_SECONDS=60
GPT_SOVITS_AUDIO_FILTER_ENABLED=true
GPT_SOVITS_NOISE_GATE_THRESHOLD_DB=-45
GPT_SOVITS_NOISE_GATE_ATTENUATION=0.2
GPT_SOVITS_HIGHPASS_HZ=70
GPT_SOVITS_LOWPASS_HZ=9000
GPT_SOVITS_AUTO_START=false
GPT_SOVITS_ROOT_DIR=
GPT_SOVITS_PYTHON_PATH=runtime/python.exe
GPT_SOVITS_API_SCRIPT=api_v2.py
GPT_SOVITS_API_CONFIG=GPT_SoVITS/configs/tts_infer.yaml
GPT_SOVITS_API_HOST=127.0.0.1
GPT_SOVITS_API_PORT=9880
GPT_SOVITS_STARTUP_TIMEOUT_SECONDS=120
GPT_SOVITS_PROBE_TIMEOUT_SECONDS=2
GPT_SOVITS_GPT_WEIGHTS_PATH=
GPT_SOVITS_SOVITS_WEIGHTS_PATH=
